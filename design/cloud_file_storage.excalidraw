      "versionNonce": 983654736,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773738494534,
      "link": null,
      "locked": false,
      "text": "Non-functional requirements\n- availability >> consistency\n- low latency upload and downloads (lowest possible)\n- support large files as 5GB\n    - resume uploads\n- high data integrity (sync accuracy)",
      "fontSize": 17.903214518229156,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional requirements\n- availability >> consistency\n- low latency upload and downloads (lowest possible)\n- support large files as 5GB\n    - resume uploads\n- high data integrity (sync accuracy)",
      "autoResize": true,
      "lineHeight": 1.25
    },
