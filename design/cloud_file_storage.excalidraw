    {
      "id": "mIAfgTUCmEelQnb5zfXbn",
      "type": "text",
      "x": 272.81768798828125,
      "y": 469.31768798828125,
      "width": 460.343785154062,
      "height": 134.2741088867187,
      "angle": 0,
