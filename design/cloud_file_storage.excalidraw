    {
      "id": "w2ylCUCmHjGm-LYW01j_G",
      "type": "text",
      "x": 277.1744689941406,
      "y": 758.0078125,
      "width": 421.64056551817475,
      "height": 338.75717157670795,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a5",
      "roundness": null,
      "seed": 171084624,
      "version": 527,
      "versionNonce": 2144547248,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773738492002,
      "link": null,
      "locked": false,
      "text": "API\n\n// presigned url\nPOST /files - > presigned url\nbody: FileMetadata\n\nPUT {presignedUrl}\nbody: fileChunk\n\nPATCH /files/ 200\nbody: Partial FileMetadata(chunk status updates)\n\n//download file\nGET /files/:fileId -> File + FileMetadata\n\n//changes\nGET /changes?since={timeStamp} -> file metadata[]",
      "fontSize": 15.941513956550967,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\n// presigned url\nPOST /files - > presigned url\nbody: FileMetadata\n\nPUT {presignedUrl}\nbody: fileChunk\n\nPATCH /files/ 200\nbody: Partial FileMetadata(chunk status updates)\n\n//download file\nGET /files/:fileId -> File + FileMetadata\n\n//changes\nGET /changes?since={timeStamp} -> file metadata[]",
      "autoResize": false,
      "lineHeight": 1.25
    },
