    {
      "id": "ZI1aGlEiet1xC0ZK2jDpS",
      "type": "text",
      "x": 770.2773308541516,
      "y": 721.5016919771837,
      "width": 565.0563295113878,
      "height": 501.55059233165866,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "ab",
      "roundness": null,
      "seed": 757549392,
      "version": 976,
      "versionNonce": 1016163760,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773738229157,
      "link": null,
      "locked": false,
      "text": "- remote changed\n    - pull for changes\n    - download the new files and replace\n\n- local changes\n    - upload the changes files to remote\n    - file watcher/fs events\n\nupload large files e.g 50gb @100mbp = 1hr 12min\n- chunk files on client to 5mb\n- fingerprint each chunk hash(bytes)\n- compression gains are not much since we need to decompress\n\nsync accuracy\n- sync to be fast\n    1. delta sync to only fetch changed chuncks\n    2. adaptive pooling (refresh button / frequency)\n- sync to be consistent\n    1. polling db\n    2. event bus with cursor\n    3. Reconcilliation: peridically poll remote files to check\nmissing files",
      "fontSize": 18.23820335751486,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- remote changed\n    - pull for changes\n    - download the new files and replace\n\n- local changes\n    - upload the changes files to remote\n    - file watcher/fs events\n\nupload large files e.g 50gb @100mbp = 1hr 12min\n- chunk files on client to 5mb\n- fingerprint each chunk hash(bytes)\n- compression gains are not much since we need to decompress\n\nsync accuracy\n- sync to be fast\n    1. delta sync to only fetch changed chuncks\n    2. adaptive pooling (refresh button / frequency)\n- sync to be consistent\n    1. polling db\n    2. event bus with cursor\n    3. Reconcilliation: peridically poll remote files to check missing files",
      "autoResize": false,
      "lineHeight": 1.25
    },
