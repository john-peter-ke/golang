      "seed": 448793910,
      "version": 89,
      "versionNonce": 772710390,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773751694502,
      "link": null,
      "locked": false,
      "text": "Problem\n- Tinder is a mobile dating app that helps people\nconnect by allowing users to swipe right to like or left\nto pass on profiles. It uses location data and user-\nspecified filters to suggest potential matches nearby.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem\n- Tinder is a mobile dating app that helps people connect by allowing users to swipe right to like or left to pass on profiles. It uses location data and user-specified filters to suggest potential matches nearby.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "_Zaq5YEUmQQNHE0_hlka-",
      "type": "text",
      "x": 272.00518798828125,
      "y": 334.6744689941406,
      "width": 529.6614379882812,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a1",
      "roundness": null,
      "seed": 400682986,
      "version": 313,
      "versionNonce": 1372621738,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773752128821,
      "link": null,
      "locked": false,
      "text": "Functional Requirements\n- users can set their preference (age, gender, etc)\n- user can view a \"stack\" of potential matches\n    - match preference\n    - close to current location\n- user can swipe left(no) / right (yes)\n- 2 users swipe right, match -> notification",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements\n- users can set their preference (age, gender, etc)\n- user can view a \"stack\" of potential matches\n    - match preference\n    - close to current location\n- user can swipe left(no) / right (yes)\n- 2 users swipe right, match -> notification",
      "autoResize": false,
      "lineHeight": 1.25
    },
