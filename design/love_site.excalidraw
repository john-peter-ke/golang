      "isDeleted": false,
      "boundElements": null,
      "updated": 1773752471150,
      "link": null,
      "locked": false,
      "text": "Non-functional Requirements\n- consistency for right swipe\n- low latency stack loading (<300ms)\n- scale to handle high writes thoughtput of 10m swipes a\nday",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional Requirements\n- consistency for right swipe\n- low latency stack loading (<300ms)\n- scale to handle high writes thoughtput of 10m swipes a day",
      "autoResize": false,
      "lineHeight": 1.25
    },
