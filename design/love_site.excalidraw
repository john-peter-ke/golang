    {
      "id": "-yIyqkclY03Tg4T0Xo3iI",
      "type": "text",
      "x": 270.3385314941406,
      "y": 1034.6744451522836,
      "width": 439.6614685058594,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a7",
      "roundness": null,
      "seed": 2064693482,
      "version": 253,
      "versionNonce": 726956086,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773753871750,
      "link": null,
      "locked": false,
      "text": "API\n\nPOST /profiles -> 201\n{\n    minAge\n    maxAge\n    gender\n    radius\n}\n\nGET /stacks?lat&lon -> profile[]\nHeader: JWT | Session\n\nPOST /swipe?userId -> match?\nHeader: JWT | Session\n{\n    decision: yes | right\n}\n    \n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n\nPOST /profiles -> 201\n{\n    minAge\n    maxAge\n    gender\n    radius\n}\n\nGET /stacks?lat&lon -> profile[]\nHeader: JWT | Session\n\nPOST /swipe?userId -> match?\nHeader: JWT | Session\n{\n    decision: yes | right\n}\n    \n",
      "autoResize": false,
      "lineHeight": 1.25
    },
