    {
      "id": "HTJ3EqflZwZwLaiTfPCaV",
      "type": "text",
      "x": 1146.0937805175781,
      "y": 1000.2603448232021,
      "width": 353.3636835154479,
      "height": 350.6510009765625,
      "angle": 0,
