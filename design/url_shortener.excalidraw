      "text": "functional Requirements\n- create a short url from long url\n    - optional support custom alias\n    - optionally support an expiration time\n- be redirected to the original url from the short url",
      "fontSize": 16.574765220047144,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "functional Requirements\n- create a short url from long url\n    - optional support custom alias\n    - optionally support an expiration time\n- be redirected to the original url from the short url",
      "autoResize": false,
      "lineHeight": 1.25
    },
