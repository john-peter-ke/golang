      "seed": 996142707,
      "version": 439,
      "versionNonce": 644732829,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773479704614,
      "link": null,
      "locked": false,
      "text": "Non-functional Requirement\n------------------------------------\n1. Systems should be highly available\nprioritizing availabiliy over consistency\n2. System scalibility to handle 2 millions views\n3. Rendor feeds in 200ms\n4. Durability is not huge concern incase comments are lost\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Non-functional Requirement\n------------------------------------\n1. Systems should be highly available\nprioritizing availabiliy over consistency\n2. System scalibility to handle 2 millions views\n3. Rendor feeds in 200ms\n4. Durability is not huge concern incase comments are lost\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
