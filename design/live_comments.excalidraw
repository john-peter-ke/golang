      "text": "Functional Requirements:\n---------------------------------\n1. Post video stream comment\n2. View video stream comments",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Functional Requirements:\n---------------------------------\n1. Post video stream comment\n2. View video stream comments",
