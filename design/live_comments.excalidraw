      "updated": 1773483202376,
      "link": null,
      "locked": false,
      "text": "API\n------\n POST /cms/create\n\nHeader: JWT\nbody: {\n content\n videoId\n timeStamp\n}\n\nGET /realtime/?time_stamp && live_video_id > []comments",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "API\n------\n POST /cms/create\n\nHeader: JWT\nbody: {\n content\n videoId\n timeStamp\n}\n\nGET /realtime/?time_stamp && live_video_id > []comments",
      "autoResize": true,
      "lineHeight": 1.25
    },
