    {
      "id": "E-tDlBw6YhWhOvi38FyTe",
      "type": "text",
      "x": 308.1510314941406,
      "y": 241.80990600585938,
      "width": 566.2593994140625,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
