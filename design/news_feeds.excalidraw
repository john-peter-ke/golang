      "link": null,
      "locked": false,
      "text": "Problem\n- Facebook is a social network which pioneered the\nNews Feed, a product which shows recent stories\nfrom users in your social graph.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Problem\n- Facebook is a social network which pioneered the News Feed, a product which shows recent stories from users in your social graph.",
      "autoResize": false,
      "lineHeight": 1.25
    },
